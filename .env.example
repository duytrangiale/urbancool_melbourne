# Copy this file to .env and fill in real values. Never commit .env.

# City of Melbourne Open Data Portal (Socrata / OpenDataSoft) — optional, higher rate limits with a key
MELBOURNE_OPEN_DATA_API_KEY=

# Bureau of Meteorology (BOM) climate data services
BOM_STATION_ID=086338
BOM_API_KEY=

# NASA FIRMS (optional, stretch goal: satellite fire/heat data)
NASA_FIRMS_API_KEY=
