# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.ipynb_checkpoints/

# Environment
.env

# Data (raw and interim are regenerated by download/cleaning scripts;
# interim alone is 500MB+ and includes files over GitHub's 100MB hard limit)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep

# Model artifacts
models/*
!models/.gitkeep

# Generated maps/reports (regenerable via src/visualization/maps.py; the Folium HTML
# embeds full choropleth GeoJSON and can run into the tens of MB)
outputs/*
!outputs/.gitkeep

# Dashboard: index.html + chart PNGs are baked by app/build_static.py from the trained
# model/predictions — regenerable, not source. styles.css/script.js ARE hand-written
# source and stay tracked.
app/static/index.html
app/static/*.png

# osmnx HTTP response cache (can grow to 1GB+; safe to regenerate)
cache/

# Personal learning notes / local assistant config / daily workflow logs — not for the public repo
UrbanCool_Melbourne_Project_Guide.md
CLAUDE.md
DAY_*.md

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
