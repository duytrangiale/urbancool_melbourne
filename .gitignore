# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.ipynb_checkpoints/

# Environment
.env

# Data (raw and interim are regenerated by download/cleaning scripts;
# interim alone is 500MB+ and includes files over GitHub's 100MB hard limit)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep

# Model artifacts
models/*
!models/.gitkeep

# osmnx HTTP response cache (can grow to 1GB+; safe to regenerate)
cache/

# Personal learning notes / local assistant config / daily workflow logs — not for the public repo
UrbanCool_Melbourne_Project_Guide.md
CLAUDE.md
DAY_*.md

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
